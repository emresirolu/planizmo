# ---- Required ----

# Neon serverless Postgres connection string (Vercel Neon integration).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js session secret. Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Google OAuth credentials (Google Cloud Console > APIs & Services > Credentials).
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
#                          http://localhost:3000/api/auth/callback/google  (for local dev)
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# ---- Optional ----

# Email (magic link) sign-in. Only enabled when both are set.
# AUTH_EMAIL_SERVER="smtp://user:pass@smtp.host:587"
# AUTH_EMAIL_FROM="Planizmo <no-reply@yourdomain.com>"
