# ---- Required ----

# Neon serverless Postgres connection string (Vercel Neon integration).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js session secret. Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Google OAuth credentials (Google Cloud Console > APIs & Services > Credentials).
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
#                          http://localhost:3000/api/auth/callback/google  (for local dev)
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# ---- Optional ----

# DeepSeek API key for the AI assistant rail (server-side only — never exposed
# to the browser). If unset, the rail degrades gracefully to grounded,
# non-AI summaries/replies built from the user's own data.
DEEPSEEK_API_KEY="sk-..."

# Secret for the nightly streak rollover cron (/api/cron/rollover). Vercel Cron
# sends it as `Authorization: Bearer <secret>` automatically when set.
CRON_SECRET="a-long-random-string"

# Health provider: "mock" (default, stable sample sleep/steps) or "fitbit".
HEALTH_PROVIDER="mock"
# Real Fitbit sync (only used when HEALTH_PROVIDER=fitbit). Off by default.
# FITBIT_CLIENT_ID="..."
# FITBIT_CLIENT_SECRET="..."

# Paddle (test/sandbox) for Pro checkout. When absent, the paywall renders but
# the buy button is disabled — the demo still works.
# PADDLE_ENV="sandbox"                  # or "production"
# PADDLE_CLIENT_TOKEN="..."             # browser token (Paddle.js)
# PADDLE_API_KEY="..."                  # server API key (reserved)
# PADDLE_WEBHOOK_SECRET="..."           # verifies /api/paddle/webhook
# PADDLE_PRICE_MONTHLY="pri_..."        # $3/mo price id
# PADDLE_PRICE_ANNUAL="pri_..."         # $20/yr price id

# Launch promo: grant Pro to ALL signed-in users until this ISO date (computed
# override, no DB writes). Unset/past = normal gating. e.g. 2026-07-31
# PRO_PROMO_UNTIL="2026-07-31"
# Always-Pro owner allow-list (comma-separated emails), even after the promo.
# OWNER_EMAILS="you@example.com"

# Email (magic link) sign-in. Only enabled when both are set.
# AUTH_EMAIL_SERVER="smtp://user:pass@smtp.host:587"
# AUTH_EMAIL_FROM="Planizmo <no-reply@yourdomain.com>"
